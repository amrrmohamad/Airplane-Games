"../../../../src/compressed-textures/ktx2/worker/loadKTX2onWorker.ts","name":null,"original":{"line":65,"column":4},"generated":{"line":51,"column":2}},{"source":"../../../../src/compressed-textures/ktx2/worker/loadKTX2onWorker.ts","name":null,"original":{"line":65,"column":5},"generated":{"line":51,"column":3}},{"source":"../../../../src/compressed-textures/ktx2/worker/loadKTX2onWorker.ts","name":null,"original":{"line":65,"column":5},"generated":{"line":51,"column":4}},{"source":"../../../../src/compressed-textures/ktx2/worker/loadKTX2onWorker.ts","name":null,"original":{"line":66,"column":0},"generated":{"line":52,"column":0}}],"sources":{"../../../../src/compressed-textures/ktx2/worker/loadKTX2onWorker.ts":"import KTXWorker from 'worker:./ktx.worker.ts';\nimport { ktxTranscoderUrls } from '../utils/setKTXTranscoderPath';\n\nimport type { TEXTURE_FORMATS } from '../../../rendering/renderers/shared/texture/const';\nimport type { TextureSourceOptions } from '../../../rendering/renderers/shared/texture/sources/TextureSource';\n\nlet ktxWorker: Worker;\nconst urlHash: Record<string, (value: any) => void> = {};\nconst errorHash: Record<string, (err: any) => void> = {};\n\nfunction getKTX2Worker(supportedTextures: TEXTURE_FORMATS[]): Worker\n{\n    if (!ktxWorker)\n    {\n        ktxWorker = new KTXWorker().worker;\n\n        ktxWorker.onmessage = (messageEvent) =>\n        {\n            const { err, success, url, textureOptions } = messageEvent.data;\n\n            if (err)\n            {\n                errorHash[url](err);\n\n                return;\n            }\n\n            if (!success)\n            {\n                console.warn('Failed to load KTX texture', url);\n            }\n\n            urlHash[url](textureOptions);\n        };\n\n        ktxWorker.postMessage({\n            type: 'init',\n            jsUrl: ktxTranscoderUrls.jsUrl,\n            wasmUrl: ktxTranscoderUrls.wasmUrl,\n            supportedTextures\n        });\n    }\n\n    return ktxWorker;\n}\n\n/**\n * @param url\n * @param supportedTextures\n * @internal\n */\nexport function loadKTX2onWorker(\n    url: string,\n    supportedTextures: TEXTURE_FORMATS[]\n): Promise<TextureSourceOptions>\n{\n    const ktxWorker = getKTX2Worker(supportedTextures);\n\n    return new Promise((resolve, reject) =>\n    {\n        urlHash[url] = resolve;\n        errorHash[url] = reject;\n\n        ktxWorker.postMessage({ type: 'load', url });\n    });\n}\n"},"lineCount":null}},"error":null,"hash":"608a27746a03fbc4224e41b696a00267","cacheData":{"env":{}}}